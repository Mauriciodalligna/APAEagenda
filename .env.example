# Banco de dados (PostgreSQL)
# Opção A: URL completa (ex.: provedores gerenciados com TLS)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Opção B: variáveis separadas (use DB_SSL=true se o servidor exigir TLS)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=apaeagenda
# DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED=false

# Em produção: defina DATABASE_URL ou DB_PASSWORD (senha vazia não é aceita sem URL).

# JWT (obrigatório em produção — mínimo 32 caracteres)
JWT_SECRET=

# URL da aplicação
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Rotas opcionais em produção (padrão: desligadas)
# ALLOW_PUBLIC_REGISTER=true
# ALLOW_TEST_EMAIL_ROUTE=true
# ENABLE_DB_CHECK=true

# E-mail (opcional - recuperação de senha)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
